{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <div class="panel mx-auto max-w-lg px-8 py-8">
        <h1 class="text-xl font-semibold text-brand">{{ title }}</h1>

        {{ form_start(form, { attr: { class: 'mt-6 space-y-5' } }) }}
            <div>
                {{ form_label(form.email, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.email, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_errors(form.email) }}
            </div>
            <div>
                {{ form_label(form.primaryRole, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.primaryRole, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_errors(form.primaryRole) }}
            </div>
            <div>
                {{ form_label(form.entreprise, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.entreprise, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_help(form.entreprise) }}
                {{ form_errors(form.entreprise) }}
            </div>
            <div>
                {{ form_label(form.managedEntreprises, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.managedEntreprises, { attr: { class: 'mt-2 block min-h-[8rem] w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_help(form.managedEntreprises) }}
                {{ form_errors(form.managedEntreprises) }}
            </div>
            <div>
                {{ form_label(form.plainPassword.first, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.plainPassword.first, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_help(form.plainPassword.first) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>
            <div>
                {{ form_label(form.plainPassword.second, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.plainPassword.second, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>
            <div class="flex flex-wrap gap-3">
                <button type="submit" class="rounded-sm bg-brand-primary px-4 py-3 text-sm font-semibold text-white hover:bg-brand-primary-hover">Enregistrer</button>
                <a class="rounded-sm border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="{{ path('admin_user_index') }}">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
