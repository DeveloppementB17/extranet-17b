{% extends 'base.html.twig' %}

{% block title %}Déclarer une intervention{% endblock %}

{% block body %}
    <div class="panel mx-auto max-w-xl px-8 py-8">
        <h1 class="text-xl font-semibold text-brand">Déclarer une intervention</h1>
        <p class="mt-2 text-sm text-slate-600">
            {% set remaining_display_in_hours = credit.remainingMinutes > 180 %}
            Crédit : <span class="font-medium">{{ credit.title }}</span> — disponible :
            <span
                class="cursor-help"
                data-tooltip-target="tc-intervention-remaining-tooltip"
                data-tooltip-placement="top"
                tabindex="0"
            >
                {{ remaining_display_in_hours ? (credit.remainingMinutes / 60)|round(2) ~ ' h' : credit.remainingMinutes ~ ' min' }}
            </span>.
            <div id="tc-intervention-remaining-tooltip" role="tooltip" class="tooltip absolute z-10 invisible inline-block rounded-base border border-default bg-neutral-primary-soft px-3 py-2 text-xs text-body opacity-0 shadow-xs">
                {{ remaining_display_in_hours ? credit.remainingMinutes ~ ' min' : (credit.remainingMinutes / 60)|round(2) ~ ' h' }}
                <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
        </p>

        {% for message in app.flashes('error') %}
            <div class="mt-4 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        {{ form_start(form, { attr: { class: 'mt-6 space-y-5' } }) }}
            <div>
                {{ form_label(form.occurredAt, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.occurredAt, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_errors(form.occurredAt) }}
            </div>
            <div>
                {{ form_label(form.durationValue, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                <div class="mt-2 grid gap-3 md:grid-cols-2">
                    {{ form_widget(form.durationValue, { attr: { class: 'block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                    <div class="rounded bg-slate-100 p-1 ring-1 ring-slate-200" data-duration-unit-switch>
                        <button type="button" class="duration-unit-btn w-1/2 rounded px-3 py-2 text-sm font-semibold text-slate-700" data-unit="minutes">
                            Minutes
                        </button><button type="button" class="duration-unit-btn w-1/2 rounded px-3 py-2 text-sm font-semibold text-slate-700" data-unit="hours">
                            Heures
                        </button>
                    </div>
                </div>
                {{ form_widget(form.durationMinutes) }}
                {{ form_widget(form.durationUnit) }}
                {{ form_errors(form.durationValue) }}
                {{ form_errors(form.durationUnit) }}
            </div>
            <div>
                {{ form_label(form.description, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.description, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="flex flex-wrap gap-3">
                <button type="submit" class="rounded-sm bg-brand-primary px-4 py-3 text-sm font-semibold text-white hover:bg-brand-primary-hover">Enregistrer l’intervention</button>
                <a class="rounded-sm border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="{{ path('time_credit_show', { id: credit.id }) }}">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
    <script>
        (() => {
            const valueField = document.getElementById('{{ form.durationValue.vars.id }}');
            const unitField = document.getElementById('{{ form.durationUnit.vars.id }}');
            const switchRoot = document.querySelector('[data-duration-unit-switch]');
            if (!valueField || !unitField || !switchRoot) {
                return;
            }

            const buttons = switchRoot.querySelectorAll('.duration-unit-btn');
            const setActive = (unit) => {
                buttons.forEach((btn) => {
                    const active = btn.dataset.unit === unit;
                    btn.classList.toggle('bg-white', active);
                    btn.classList.toggle('text-brand', active);
                    btn.classList.toggle('shadow-sm', active);
                    btn.classList.toggle('text-slate-700', !active);
                });
            };

            const convertValue = (fromUnit, toUnit) => {
                const raw = parseFloat(valueField.value.replace(',', '.'));
                if (Number.isNaN(raw) || fromUnit === toUnit) {
                    return;
                }

                const converted = fromUnit === 'minutes' ? raw / 60 : raw * 60;
                const precision = toUnit === 'hours' ? 2 : 0;
                valueField.value = converted.toFixed(precision).replace(/\.00$/, '');
            };

            buttons.forEach((btn) => {
                btn.addEventListener('click', () => {
                    const nextUnit = btn.dataset.unit;
                    const previousUnit = unitField.value || 'minutes';
                    convertValue(previousUnit, nextUnit);
                    unitField.value = nextUnit;
                    setActive(nextUnit);
                });
            });

            setActive(unitField.value || 'minutes');
        })();
    </script>
{% endblock %}
