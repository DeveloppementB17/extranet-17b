<div class="panel-muted rounded-sm p-5">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">Déclarer une intervention</h2>

    {% if selected_entreprise is not null %}
        <p class="mt-2 text-sm text-slate-700">
            Entreprise active : <span class="font-medium">{{ selected_entreprise.name }}</span>
        </p>
        {% if has_available_credits %}
            {{ form_start(form, { attr: { class: 'mt-4 space-y-4' } }) }}
                <div>
                    {{ form_label(form.timeCredit, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                    {{ form_widget(form.timeCredit, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                    {{ form_errors(form.timeCredit) }}
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        {{ form_label(form.occurredAt, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                        {{ form_widget(form.occurredAt, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                        {{ form_errors(form.occurredAt) }}
                    </div>
                    <div>
                        {{ form_label(form.durationMinutes, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                        {{ form_widget(form.durationMinutes, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                        {{ form_errors(form.durationMinutes) }}
                    </div>
                </div>
                <div>
                    {{ form_label(form.description, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                    {{ form_widget(form.description, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                    {{ form_errors(form.description) }}
                </div>
                {{ form_widget(form.returnTo) }}
                <button type="submit" class="rounded-sm bg-brand-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-primary-hover">
                    Enregistrer l’intervention
                </button>
            {{ form_end(form) }}
        {% else %}
            <p class="mt-3 text-sm text-slate-700">Aucun crédit actif avec minutes disponibles pour cette entreprise.</p>
        {% endif %}
    {% else %}
        <p class="mt-2 text-sm text-slate-700">Sélectionne d’abord une entreprise pour déclarer une intervention.</p>
    {% endif %}
</div>
