{% set routeName = app.request.attributes.get('_route') %}
{% set sidebarActiveClient = managed_selected_client() %}
<aside class="flex w-[360px] shrink-0 flex-col border-r border-neutral-200 bg-[#f8f8f8] px-7 pb-8 pt-8" aria-label="Navigation">
    <a href="{{ path('app_home') }}" class="mb-12 block">
        <img src="{{ asset('images/logo-b17-communication.png') }}" alt="B17 communication" width="78" height="58" class="h-[58px] w-auto max-w-[120px] object-contain object-left">
    </a>

    <nav class="flex flex-1 flex-col gap-1 text-base text-black">
        <a href="{{ path('app_home') }}" class="dashboard-nav-item flex items-center gap-3 py-2 font-['Sora',sans-serif] {{ routeName == 'app_home' ? 'font-extrabold' : 'font-normal' }}">
            <svg class="h-[22px] w-[22px] shrink-0 stroke-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
            Accueil
        </a>
        <a href="{{ path('document_index') }}" class="dashboard-nav-item flex items-center gap-3 py-2 font-['Sora',sans-serif] {{ routeName starts with 'document_' ? 'font-extrabold' : 'font-normal' }}">
            <svg class="h-[22px] w-[22px] shrink-0 stroke-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a15.995 15.995 0 0 1-3.428 1.616m-6.09 4.158a15.996 15.996 0 0 1-4.05-4.05m4.05 4.05a15.996 15.996 0 0 0 4.05-4.05"/></svg>
            Fichiers
        </a>
        <span class="dashboard-nav-item flex cursor-not-allowed items-center gap-3 py-2 font-['Sora',sans-serif] font-normal text-slate-400 opacity-70" aria-disabled="true" title="Bientôt disponible">
            <svg class="h-[22px] w-[22px] shrink-0 stroke-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            Stratégie
        </span>
        <a href="{{ path('time_credit_index') }}" class="dashboard-nav-item flex items-center gap-3 py-2 font-['Sora',sans-serif] {{ routeName starts with 'time_credit_' ? 'font-extrabold' : 'font-normal' }}">
            <svg class="h-[22px] w-[22px] shrink-0 stroke-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z"/></svg>
            Crédit temps
        </a>
        {% if is_granted('ROLE_CUSTOMER_ADMIN') %}
            <a href="{{ path('customer_user_index') }}" class="dashboard-nav-item flex items-center gap-3 py-2 font-['Sora',sans-serif] {{ routeName starts with 'customer_user_' ? 'font-extrabold' : 'font-normal' }}">
                <svg class="h-[22px] w-[22px] shrink-0 stroke-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-3.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
                Utilisateurs
            </a>
        {% endif %}
        {% if is_granted('ROLE_17B_ADMIN') %}
            <a href="{{ path('admin_dashboard') }}" class="dashboard-nav-item mt-2 flex items-center gap-3 border-t border-neutral-200 pt-4 py-2 text-sm font-['Sora',sans-serif] font-semibold text-neutral-800 hover:text-black">
                <svg class="h-[22px] w-[22px] shrink-0 stroke-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.99l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.37.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.542-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.992a7.723 7.723 0 0 1 0-.255c.007-.38-.138-.751-.43-.99l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                Administration
            </a>
        {% endif %}
    </nav>

    <div class="mt-auto border-t border-neutral-300 pt-6">
        {% if is_granted('ROLE_17B_ADMIN') or is_granted('ROLE_17B_USER') %}
            <div class="mb-6 [&_select]:max-w-full [&_select]:text-xs [&_span]:text-xs">
                {{ render(path('header_staff_client_switcher', { return_to: app.request.requestUri })) }}
            </div>
        {% endif %}

        <div class="flex items-start gap-3">
            <div class="flex h-[51px] w-[51px] shrink-0 items-center justify-center rounded-full bg-neutral-900 text-xl font-medium text-white" aria-hidden="true">
                {% set initials = app.user.userIdentifier|slice(0, 1)|upper %}
                {{ initials }}
            </div>
            <div class="min-w-0 flex-1">
                <p class="font-['Sora',sans-serif] text-sm font-extrabold leading-tight text-black">
                    {{ app.user.userIdentifier }}
                </p>
                <a href="{{ path('app_account') }}" class="mt-1 inline-flex items-center gap-1.5 font-['Sora',sans-serif] text-sm font-normal text-black hover:underline">
                    Modifier le compte
                    <svg class="h-[15px] w-[15px]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.65 7.758"/></svg>
                </a>
            </div>
        </div>

        <a href="{{ path('app_logout') }}" class="dashboard-logout-link mt-6 inline-block font-['Proxima_Nova','Inter',sans-serif] text-base font-bold text-black">
            Déconnexion
        </a>
    </div>
</aside>
