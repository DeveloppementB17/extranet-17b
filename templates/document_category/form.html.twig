{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <div class="panel mx-auto max-w-lg px-8 py-8">
        <h1 class="text-xl font-semibold text-brand">{{ title }}</h1>

        {{ form_start(form, { attr: { class: 'mt-6 space-y-5' } }) }}
            {% if form.entreprise is defined %}
                <div>
                    {{ form_label(form.entreprise, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                    {{ form_widget(form.entreprise, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                    {{ form_errors(form.entreprise) }}
                </div>
            {% endif %}
            <div>
                {{ form_label(form.name, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.name, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {% if form.name.vars.errors|length %}
                    <div class="mt-2 text-sm text-red-700">
                        {% for error in form.name.vars.errors %}
                            <div>{{ error.message }}</div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <div>
                {{ form_label(form.parent, null, { label_attr: { class: 'block text-sm font-semibold text-slate-600' } }) }}
                {{ form_widget(form.parent, { attr: { class: 'mt-2 block w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary' } }) }}
                {{ form_errors(form.parent) }}
            </div>
            <div class="flex flex-wrap gap-3">
                <button type="submit" class="rounded-sm bg-brand-primary px-4 py-3 text-sm font-semibold text-white hover:bg-brand-primary-hover">Enregistrer</button>
                <a class="rounded-sm border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="{{ path('document_category_index') }}">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
