{% extends 'auth/_layout.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block auth_body %}
        <h1 class="text-center text-2xl font-semibold text-brand">Nouveau mot de passe</h1>
        <p class="mt-3 text-center text-sm text-slate-600">
            Choisis un nouveau mot de passe.
        </p>

        {% for message in app.flashes('error') %}
            <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        <form class="mt-8 space-y-6" action="{{ path('auth_reset_password', { token: token }) }}" method="post">
            <div>
                <label class="block text-sm font-semibold text-slate-600" for="password">Mot de passe</label>
                <input class="mt-2 w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary" type="password" id="password" name="password" autocomplete="new-password" required>
                <div class="mt-2 text-xs text-slate-500">Minimum 10 caractères.</div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <button class="w-full rounded-sm bg-brand-primary px-4 py-3 text-sm font-semibold text-white hover:bg-brand-primary-hover" type="submit">
                Mettre à jour
            </button>
        </form>

        <div class="mt-6 text-center text-sm text-slate-600">
            <a class="font-medium text-brand underline" href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>
{% endblock %}

