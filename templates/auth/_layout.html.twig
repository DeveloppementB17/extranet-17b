{% extends 'base.html.twig' %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
    <div class="min-h-screen bg-brand">
        <div class="mx-auto grid min-h-screen max-w-6xl grid-cols-1 items-center gap-10 px-6 py-10 lg:grid-cols-2">
            <section class="hidden lg:block">
                <div class="max-w-lg">
                    <div class="flex items-center gap-4">
                        <div class=" p-3">
                            <img src="{{ asset('images/logo-17b.png') }}" alt="Logo 17b" class="h-24 w-auto">
                        </div>
                    </div>

                    <h1 class="mt-10 text-5xl font-extrabold leading-tight text-brand">
                        Bienvenue sur<br>
                        votre espace<br>
                        client 17b !
                    </h1>
                </div>
            </section>

            <section>
                <div class="mx-auto w-full max-w-md rounded-sm bg-brand-card px-10 py-10 shadow-[0_30px_60px_rgba(0,0,0,0.10)]">
                    {% block auth_body %}{% endblock %}
                </div>
            </section>
        </div>
    </div>
{% endblock %}

