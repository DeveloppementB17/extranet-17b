{% extends 'base.html.twig' %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
    <div class="min-h-screen bg-brand">
        <div class="mx-auto grid min-h-screen max-w-7xl grid-cols-1 items-center gap-12 px-6 py-10 lg:grid-cols-2">
            <section class="hidden lg:block">
                <div class="max-w-xl">
                    <div class="mb-12">
                        <img src="{{ asset('images/logo-b17-communication.png') }}" alt="Logo B17 communication" class="h-28 w-auto">
                    </div>
                    <h1 class="mt-8 text-6xl font-extrabold leading-tight text-brand">
                        Bienvenue sur<br>
                        votre espace<br>
                        client 17b !
                    </h1>
                </div>
            </section>

            <section>
                <div class="mx-auto w-full max-w-[528px] bg-brand-card px-16 py-20">
                    {% block auth_body %}{% endblock %}
                </div>
            </section>
        </div>

        {% if app.environment == 'dev' %}
            <div class="mx-auto max-w-7xl px-6 pb-6">
                <div class="flex rounded border border-green-200 bg-green-50 p-4 text-sm text-green-800" role="alert">
                    <svg class="me-2 h-4 w-4 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path></svg>
                    <div>
                        <span class="font-medium">Comptes de test</span>
                        <ul class="mt-2 list-outside list-disc space-y-1 ps-2.5">
                            <li><span class="font-medium">ROLE_17B_ADMIN</span> (compte de test) — <span class="font-mono">admin-test@17b.test</span> / <span class="font-mono">ChangeMe123!</span></li>
                            <li><span class="font-medium">ROLE_17B_USER</span> — <span class="font-mono">staff-partial@17b.test</span> <span class="text-slate-500">(Cliente Nord uniquement)</span> / <span class="font-mono">ChangeMe123!</span></li>
                            <li class="border-t border-slate-200 pt-2 text-slate-700">Cliente Nord (<span class="font-mono">demo-nord</span>)</li>
                            <li><span class="font-medium">ROLE_CUSTOMER_ADMIN</span> — <span class="font-mono">admin-nord@clients.test</span></li>
                            <li><span class="font-medium">ROLE_CUSTOMER_USER</span> — <span class="font-mono">user-nord@clients.test</span></li>
                            <li class="border-t border-slate-200 pt-2 text-slate-700">Cliente Sud (<span class="font-mono">demo-sud</span>)</li>
                            <li><span class="font-medium">ROLE_CUSTOMER_ADMIN</span> — <span class="font-mono">admin-sud@clients.test</span></li>
                            <li><span class="font-medium">ROLE_CUSTOMER_USER</span> — <span class="font-mono">user-sud@clients.test</span></li>
                            <li class="border-t border-slate-200 pt-2 text-slate-700">Cliente Est (<span class="font-mono">demo-est</span>)</li>
                            <li><span class="font-medium">ROLE_CUSTOMER_ADMIN</span> — <span class="font-mono">admin-est@clients.test</span></li>
                            <li><span class="font-medium">ROLE_CUSTOMER_USER</span> — <span class="font-mono">user-est@clients.test</span></li>
                            <li class="text-xs text-slate-600">Mot de passe partout : <span class="font-mono">ChangeMe123!</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
