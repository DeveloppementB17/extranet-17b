{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md">
        <h1 class="text-2xl font-semibold">Connexion</h1>

        {% for message in app.flashes('error') %}
            <div class="mt-4 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="mt-4 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form class="mt-6 space-y-4" action="{{ path('app_login') }}" method="post">
            <div>
                <label class="block text-sm font-medium" for="username">Email</label>
                <input class="mt-1 w-full rounded border border-slate-300 px-3 py-2" type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required>
            </div>

            <div>
                <label class="block text-sm font-medium" for="password">Mot de passe</label>
                <input class="mt-1 w-full rounded border border-slate-300 px-3 py-2" type="password" id="password" name="_password" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="w-full rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" type="submit">
                Se connecter
            </button>
        </form>

        <div class="mt-6 text-sm text-slate-700">
            Ou bien
            <a class="font-medium text-slate-900 underline" href="{{ path('auth_code') }}">recevoir un code unique par email</a>.
        </div>

        {% if app.environment == 'dev' %}
            <div class="mt-8 rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
                <div class="font-semibold text-slate-900">Comptes de test (local)</div>
                <div class="mt-2 space-y-1 text-slate-800">
                    <div><span class="font-medium">ROLE_ADMIN</span> — admin@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                    <div><span class="font-medium">ROLE_MANAGER</span> — manager@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                    <div><span class="font-medium">ROLE_CLIENT</span> — client@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                    <div><span class="font-medium">ROLE_USER</span> — user@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                </div>
                <div class="mt-2 text-xs text-slate-600">
                    Visible uniquement en <span class="font-mono">APP_ENV=dev</span>.
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}

