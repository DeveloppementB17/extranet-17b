{% extends 'auth/_layout.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block auth_body %}
        <h1 class="text-center text-2xl font-semibold text-brand">Connexion</h1>

        {% for message in app.flashes('error') %}
            <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form class="mt-8 space-y-6" action="{{ path('app_login') }}" method="post">
            <div>
                <label class="block text-sm font-semibold text-slate-600" for="username">Identifiant</label>
                <input class="mt-2 w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary" type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600" for="password">Mot de passe</label>
                <input class="mt-2 w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary" type="password" id="password" name="_password" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="w-full rounded-sm bg-brand-primary px-4 py-3 text-sm font-semibold text-white hover:bg-brand-primary-hover" type="submit">
                Connexion
            </button>
        </form>

        <div class="mt-6 flex items-center justify-between text-sm text-slate-600">
            <a class="font-medium text-brand underline" href="{{ path('auth_code') }}">Code unique par email</a>
            <a class="font-medium text-brand underline" href="{{ path('auth_forgot_password') }}">Mot de passe oublié ?</a>
        </div>

        {% if app.environment == 'dev' %}
            <div class="mt-8 rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
                <div class="font-semibold text-slate-900">Comptes de test (local)</div>
                <div class="mt-2 space-y-1 text-slate-800">
                    <div><span class="font-medium">ROLE_ADMIN</span> — admin@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                    <div><span class="font-medium">ROLE_MANAGER</span> — manager@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                    <div><span class="font-medium">ROLE_CLIENT</span> — client@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                    <div><span class="font-medium">ROLE_USER</span> — user@17b.test / <span class="font-mono">ChangeMe123!</span></div>
                </div>
                <div class="mt-2 text-xs text-slate-600">
                    Visible uniquement en <span class="font-mono">APP_ENV=dev</span>.
                </div>
            </div>
        {% endif %}
{% endblock %}

