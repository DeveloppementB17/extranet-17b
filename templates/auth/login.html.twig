{% extends 'auth/_layout.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block auth_body %}
        <h1 class="text-5xl font-extrabold text-brand">Connexion</h1>

        {% for message in app.flashes('error') %}
            <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

    
        <form class="mt-12 space-y-10" action="{{ path('app_login') }}" method="post">
            <div>
                <label class="block text-lg font-semibold text-brand" for="username">Identifiant</label>
                <input class="mt-3 w-full border-0 border-b border-slate-600 bg-transparent px-0 py-2 text-lg font-semibold text-slate-900 outline-none focus:border-brand" type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required>
            </div>

            <div>
                <label class="block text-lg font-semibold text-brand" for="password">Mot de passe</label>
                <input class="mt-3 w-full border-0 border-b border-slate-600 bg-transparent px-0 py-2 text-lg text-slate-900 outline-none focus:border-brand" type="password" id="password" name="_password" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="ml-auto block bg-brand-primary px-6 py-2 text-xl font-bold text-white hover:bg-brand-primary-hover button" type="submit">
                Connexion
            </button>
        </form>

        <div class="mt-10 space-y-4 text-lg text-slate-900">
            <a class="block w-fit font-semibold text-brand underline underline-offset-2" href="{{ path('auth_code') }}">Code unique par email</a>
            <a class="block w-fit font-semibold text-brand underline underline-offset-2" href="{{ path('auth_forgot_password') }}">Mot de passe oublié ?</a>
        </div>


{% endblock %}

