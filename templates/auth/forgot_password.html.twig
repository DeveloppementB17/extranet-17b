{% extends 'auth/_layout.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block auth_body %}
        <h1 class="text-center text-2xl font-semibold text-brand">Mot de passe oublié</h1>
        <p class="mt-3 text-center text-sm text-slate-600">
            Saisis ton email. Si un compte existe, tu recevras un lien de réinitialisation.
        </p>

        {% for message in app.flashes('success') %}
            <div class="mt-6 rounded border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        <form class="mt-8 space-y-6" action="{{ path('auth_forgot_password') }}" method="post">
            <div>
                <label class="block text-sm font-semibold text-slate-600" for="email">Email</label>
                <input class="mt-2 w-full rounded bg-slate-100 px-3 py-2 text-slate-900 outline-none ring-1 ring-slate-200 focus:ring-2 focus:ring-brand-primary" type="email" id="email" name="email" autocomplete="email" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <button class="w-full rounded-sm bg-brand-primary px-4 py-3 text-sm font-semibold text-white hover:bg-brand-primary-hover" type="submit">
                Envoyer le lien
            </button>
        </form>

        <div class="mt-6 text-center text-sm text-slate-600">
            <a class="font-medium text-brand underline" href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>

        {% if app.environment == 'dev' %}
            <div class="mt-6 rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
                <div class="font-semibold">Mode dev</div>
                <div class="mt-1">
                    Le lien arrive dans Mailhog/Mailpit :
                    <a class="font-medium underline" href="http://127.0.0.1:8025" target="_blank" rel="noopener noreferrer">ouvrir l’interface email</a>.
                </div>
            </div>
        {% endif %}
{% endblock %}

