{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <div class="panel mx-auto max-w-xl px-10 py-10">
        {% for message in app.flashes('success') %}
            <div class="mb-4 rounded border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        <div class="space-y-4">
            <h1 class="text-2xl font-semibold text-brand">Extranet 17b</h1>
            <p class="text-slate-700">
                Connecté en tant que <span class="font-medium">{{ app.user.userIdentifier }}</span>.
            </p>
            <div class="panel-muted rounded-sm p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">Actions disponibles</h2>
                <ul class="mt-3 space-y-2 text-sm text-slate-700">
                    {% if is_granted('ROLE_17B_ADMIN') %}
                        <li>
                            <a class="font-medium text-brand underline" href="{{ path('admin_dashboard') }}">Administration</a>
                            <span> — gérer les entreprises et les utilisateurs.</span>
                        </li>
                        {% if selected_client %}
                            <li>
                                <span class="font-medium text-brand">Client actif : {{ selected_client.name }}</span>
                            </li>
                            <li>
                                <a class="font-medium text-brand underline" href="{{ path('document_index') }}">Consulter les documents</a>
                                <span> — accès ciblé sur l’entreprise attribuée sélectionnée.</span>
                            </li>
                            <li>
                                <a class="font-medium text-brand underline" href="{{ path('document_batch_upload') }}">Ajouter des documents</a>
                                <span> — dépôt sur le client attribué sélectionné.</span>
                            </li>
                        {% endif %}
                        <li>
                            <a class="font-medium text-brand underline" href="{{ path('document_batch_upload') }}">Ajouter des documents</a>
                            <span> — dépôt groupé pour les clients.</span>
                        </li>
                        <li>
                            <a class="font-medium text-brand underline" href="{{ path('document_category_index') }}">Gérer les dossiers</a>
                            <span> — structurer l’arborescence documentaire.</span>
                        </li>
                    {% elseif is_granted('ROLE_17B_USER') %}
                        <li class="text-slate-800">
                            Choisis un client ci-dessous pour activer l’accès à ses documents.
                        </li>
                        {% if selected_client %}
                            <li>
                                <span class="font-medium text-brand">Client actif : {{ selected_client.name }}</span>
                            </li>
                            <li>
                                <a class="font-medium text-brand underline" href="{{ path('document_index') }}">Consulter les documents</a>
                                <span> — accès limité au client sélectionné.</span>
                            </li>
                            <li>
                                <a class="font-medium text-brand underline" href="{{ path('document_batch_upload') }}">Ajouter des documents</a>
                                <span> — dépôt sur le client sélectionné.</span>
                            </li>
                        {% else %}
                            <li class="text-amber-800">
                                Aucun client actif pour le moment.
                            </li>
                        {% endif %}
                    {% elseif is_granted('ROLE_CUSTOMER_ADMIN') %}
                        <li>
                            <a class="font-medium text-brand underline" href="{{ path('document_index') }}">Consulter les documents</a>
                            <span> — visualiser les documents de votre entreprise.</span>
                        </li>
                        <li>
                            <a class="font-medium text-brand underline" href="{{ path('customer_user_index') }}">Gérer les utilisateurs</a>
                            <span> — créer, modifier ou supprimer les comptes utilisateurs de votre entreprise.</span>
                        </li>
                    {% else %}
                        <li>
                            <a class="font-medium text-brand underline" href="{{ path('document_index') }}">Consulter les documents</a>
                            <span> — accès en lecture à votre espace client.</span>
                        </li>
                    {% endif %}
                    <li>
                        <a class="font-medium text-brand underline" href="{{ path('app_account') }}">Mon compte</a>
                        <span> — mettre à jour votre profil et mot de passe.</span>
                    </li>
                    <li>
                        <a class="font-medium text-brand underline" href="{{ path('app_logout') }}">Se déconnecter</a>
                    </li>
                </ul>
            </div>

            {% if is_granted('ROLE_17B_ADMIN') or is_granted('ROLE_17B_USER') %}
                <div class="panel-muted rounded-sm p-5">
                    <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">
                        {% if is_granted('ROLE_17B_ADMIN') %}Entreprises attribuées{% else %}Mes clients{% endif %}
                    </h2>
                    {% if managed_clients is empty %}
                        <p class="mt-3 text-sm text-slate-700">
                            {% if is_granted('ROLE_17B_ADMIN') %}
                                Aucune entreprise cliente attribuée à ce compte admin 17b.
                            {% else %}
                                Aucun client n’est actuellement associé à ton compte.
                            {% endif %}
                        </p>
                    {% else %}
                        <div class="mt-3 flex flex-wrap gap-2">
                            {% for client in managed_clients %}
                                <form method="post" action="{{ path('staff_client_select', { id: client.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('select_client_' ~ client.id) }}">
                                    <button
                                        type="submit"
                                        class="rounded-sm px-3 py-2 text-sm font-medium {{ selected_client and selected_client.id == client.id ? 'bg-brand-primary text-white' : 'bg-slate-100 text-slate-800 hover:bg-slate-200' }}"
                                    >
                                        {{ client.name }}
                                    </button>
                                </form>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

