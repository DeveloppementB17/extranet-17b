{% extends 'base.html.twig' %}

{% block title %}Catégories de crédits temps{% endblock %}

{% block body %}
    <div class="panel px-8 py-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <h1 class="text-xl font-semibold text-brand">Catégories de crédits temps</h1>
            <a class="rounded-sm bg-brand-primary px-4 py-2 text-sm font-semibold text-white hover:bg-brand-primary-hover" href="{{ path('time_credit_category_new') }}">Nouvelle catégorie</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="mt-4 rounded border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mt-4 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
        {% endfor %}

        <div class="mt-6 overflow-hidden rounded ring-1 ring-slate-200">
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-4 py-3 font-semibold">Nom</th>
                        <th class="px-4 py-3 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                    {% for c in categories %}
                        <tr>
                            <td class="px-4 py-3 text-slate-900">{{ c.name }}</td>
                            <td class="px-4 py-3 text-right">
                                <a class="font-medium text-brand underline" href="{{ path('time_credit_category_edit', { id: c.id }) }}">Modifier</a>
                                <form class="ml-3 inline" method="post" action="{{ path('time_credit_category_delete', { id: c.id }) }}" onsubmit="return confirm('Supprimer cette catégorie ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_time_credit_category' ~ c.id) }}">
                                    <button type="submit" class="font-medium text-red-700 underline">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="px-4 py-6 text-slate-600">Aucune catégorie pour le moment.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
